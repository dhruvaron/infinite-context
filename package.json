{
  "name": "continuum",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "node --import tsx scripts/dev.ts",
    "start": "node --import tsx scripts/start.ts",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:headed": "playwright test --headed",
    "lint": "eslint .",
    "format": "prettier --write .",
    "audit:security": "node --import tsx scripts/security-audit.ts",
    "contracts:check": "node --import tsx scripts/check-contract-coverage.ts",
    "hygiene:conflicts": "node --import tsx scripts/check-conflict-copies.ts",
    "test:native-ingestion": "node --import tsx scripts/native-ingestion-smoke.ts",
    "test:macos-sandbox": "node --import tsx scripts/sandbox-smoke.ts",
    "eval": "node --import tsx packages/evaluation/src/cli.ts",
    "eval:no-cost": "node --import tsx packages/evaluation/src/cli.ts --output artifacts/evaluation/no-cost",
    "eval:import-dataset": "node --import tsx packages/evaluation/src/public-dataset-cli.ts",
    "eval:latency": "node --import tsx packages/evaluation/src/latency-cli.ts",
    "eval:live": "node --import tsx packages/evaluation/src/live-cli.ts",
    "eval:causal": "node --import tsx packages/evaluation/src/causal-cli.ts",
    "eval:competitors": "node --import tsx packages/evaluation/src/competitor-cli.ts",
    "load:quick": "node --import tsx scripts/load-test.ts --quick --output artifacts/evaluation/load-quick.json",
    "load:full": "node --import tsx scripts/load-test.ts --output artifacts/evaluation/load-full.json",
    "evidence:no-cost": "pnpm load:full && pnpm eval:no-cost -- --load-report artifacts/evaluation/load-full.json",
    "clean": "pnpm -r --if-present clean"
  },
  "dependencies": {
    "@continuum/config": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.1",
    "@types/node": "^24.0.15",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
